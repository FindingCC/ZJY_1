generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id            Int            @id @default(autoincrement())
  name          String
  description   String?
  createdAt     DateTime       @default(now())
  projectNodes  ProjectNode[]
  archivedFiles ArchivedFile[]
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("USER")
  createdAt DateTime @default(now())
}

model ConstructionTemplate {
  id              Int                      @id @default(autoincrement())
  name            String
  description     String?
  order           Int
  category        String
  defaultDays     Int                      @default(0)
  createdAt       DateTime                 @default(now())
  checklistItems  TemplateChecklistItem[]
  projectNodes    ProjectNode[]
}

model TemplateChecklistItem {
  id         Int                  @id @default(autoincrement())
  templateId Int
  content    String
  order      Int
  template   ConstructionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ProjectNode {
  id              Int               @id @default(autoincrement())
  name            String
  description     String?
  order           Int
  startDate       String?
  endDate         String?
  status          String            @default("PENDING")
  templateId      Int?
  projectId       Int
  template        ConstructionTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  checklistItems  ChecklistItem[]
  reminderLogs    ReminderLog[]
  archivedFiles   ArchivedFile[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model ChecklistItem {
  id            Int         @id @default(autoincrement())
  projectNodeId Int
  content       String
  isCompleted   Boolean     @default(false)
  order         Int
  projectNode   ProjectNode @relation(fields: [projectNodeId], references: [id], onDelete: Cascade)
}

model ArchivedFile {
  id            Int          @id @default(autoincrement())
  projectNodeId Int?
  projectId     Int
  originalName  String
  storedPath    String
  fileSize      Int
  captureDate   String?
  status        String       @default("CLASSIFIED")
  createdAt     DateTime     @default(now())
  projectNode   ProjectNode? @relation(fields: [projectNodeId], references: [id], onDelete: SetNull)
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ReminderLog {
  id            Int         @id @default(autoincrement())
  projectNodeId Int?
  reminderType  String
  sentAt        DateTime    @default(now())
  isRead        Boolean     @default(false)
  projectNode   ProjectNode? @relation(fields: [projectNodeId], references: [id], onDelete: Cascade)
}
